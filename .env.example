# ClashAnime environment variables
# Copy to `.env.local` for local dev, then set the same keys in Vercel → Settings → Environment Variables.

# ── Watch site gate (watchclashanime.com) ───────────────────────────
WATCH_SITE_URL=https://watchclashanime.com
WATCH_GATE_SECRET=generate-a-long-random-secret-min-32-chars

# Watch Clash Anime Supabase (for /admin/watch-anime panel)
# IMPORTANT: Supabase API URL ends with .supabase.co (NOT .com)
WATCH_SUPABASE_URL=https://syejgapabecrbiqonsob.supabase.co
WATCH_SUPABASE_SERVICE_ROLE_KEY=your-watch-service-role-key

# ── Supabase (required) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 media (required for uploads) ───────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://media.clashanime.com
R2_UPLOAD_SECRET=
NEXT_PUBLIC_R2_UPLOAD_URL=https://upload.clashanime.com

# Optional S3 endpoint override
# R2_S3_ENDPOINT=

# ── Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="ClashAnime <noreply@clashanime.com>"
CONTACT_NOTIFY_EMAIL=clashanime.team@gmail.com

# ── Cron jobs (GitHub Actions + optional Vercel cron) ──────────────
CRON_SECRET=generate-a-long-random-secret
# SITE_URL=https://www.clashanime.com

# ── Admin bootstrap (one-time) ─────────────────────────────────────
ADMIN_SETUP_TOKEN=

# ── TrafficStars — DISABLED on clashanime.com (AdSense-only property) ──
# Do not enable TrafficStars here. Use watchclashanime.com (separate project) if needed.
# NEXT_PUBLIC_TRAFFICSTARS_BANNER_SPOT=
# NEXT_PUBLIC_TRAFFICSTARS_POPUNDER_URL=

# ── HilltopAds — DISABLED on clashanime.com (AdSense policy) ──
# Do NOT enable Hilltop on this AdSense property.
# NEXT_PUBLIC_HILLTOPADS_ENABLED=false
# NEXT_PUBLIC_HILLTOPADS_POPUNDER_URL=
# NEXT_PUBLIC_HILLTOPADS_BANNER_URL=
# NEXT_PUBLIC_HILLTOPADS_VIDEO_SLIDER_URL=

# Get these from https://adsense.google.com after site status is Ready (جاهز).
# Publisher: ca-pub-9998186124580672 — clashanime.com must show Ready before ads fill.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-9998186124580672
# Create Display / In-article units under Ads → By ad unit, then paste slot IDs:
NEXT_PUBLIC_ADSENSE_SLOT=
# NEXT_PUBLIC_ADSENSE_SLOT_INFEED=
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
# Auto ads (no slot needed): enable in AdSense UI for clashanime.com; script loads site-wide.
# NEXT_PUBLIC_ADSENSE_AUTO_ADS=true

# ── Local development helpers ───────────────────────────────────────
# NODE_ENV=development
